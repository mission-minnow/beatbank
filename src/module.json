{
    "id": "beatbank",
    "name": "Beat Bank",
    "abbrev": "BANK",
    "version": "0.1.0",
    "description": "Library of standard drum patterns from editable .beat files — pick a pattern, it prints one bar into Move.",
    "author": "Schwung Move",
    "api_version": 2,
    "dsp": "dsp.so",
    "capabilities": {
        "midi_in": true,
        "midi_out": true,
        "chainable": true,
        "component_type": "midi_fx",
        "ui_hierarchy": {
            "levels": {
                "root": {
                    "name": "Beat Bank",
                    "params": [
                        { "level": "patterns", "label": "Pattern" },
                        "note_map"
                    ],
                    "knobs": ["note_map"]
                },
                "patterns": {
                    "name": "Pattern",
                    "list_param": "pattern",
                    "count_param": "pattern_count",
                    "name_param": "pattern_label",
                    "knobs": ["pattern"]
                }
            }
        }
    },
    "chain_params": [
        { "key": "pattern", "name": "Pattern", "type": "int", "min": 0, "max": 399, "default": 0, "step": 1 },
        { "key": "note_map", "name": "Note Map", "type": "enum", "options": ["gm", "drumrack"], "default": 0 }
    ]
}
