{
    "id": "beatbank",
    "name": "Beat Bank",
    "abbrev": "BANK",
    "version": "0.1.1",
    "description": "Library of standard drum patterns from editable .beat files — pick a pattern, it prints one bar into Move.",
    "author": "Schwung Move",
    "api_version": 2,
    "dsp": "dsp.so",
    "capabilities": {
        "midi_in": true,
        "midi_out": true,
        "chainable": true,
        "component_type": "midi_fx",
        "pre_capable": true,
        "ui_hierarchy": {
            "levels": {
                "root": {
                    "name": "Beat Bank",
                    "params": [
                        { "key": "view", "name": "Pattern", "type": "canvas", "canvas_script": "canvas.js", "show_value": false, "show_footer": false },
                        { "level": "globals", "label": "Globals" }
                    ]
                },
                "globals": {
                    "name": "Globals",
                    "params": ["swing", "note_map"],
                    "knobs": ["swing", "note_map"]
                }
            }
        }
    },
    "chain_params": [
        { "key": "pattern", "name": "Pattern", "type": "int", "min": 0, "max": 599, "default": 0, "step": 1 },
        { "key": "swing", "name": "Swing", "type": "int", "min": 0, "max": 100, "default": 0, "step": 1, "unit": "%" },
        { "key": "note_map", "name": "Note Map", "type": "enum", "options": ["gm", "drumrack"], "default": 1 }
    ]
}
